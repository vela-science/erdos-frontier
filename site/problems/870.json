{"accepted":[{"assertion":"AI-contributions wiki claim — wiki: Candidate full solution.","id":"vf_86e95433811dacd7","trust":"signed","type":"theoretical"},{"assertion":"Erdős Problem #870: declared status 'open'. Formalized: no. Let $k\\geq 3$ and $A$ be an additive basis of order $k$. Does there exist a constant $c=c(k)>0$ such that if $r(n)\\geq c\\log n$ for all large $n$ then $A$ must contain a minimal basis of order $k$? (Here $r(n)$ counts the number of representations of $n$ as the sum of at most $k$ elements from $A$.) Prize: no. Tags: additive basis, number theory.","id":"vf_873090b4992176be","trust":"signed","type":"theoretical"}],"accepted_activity":false,"activity":[],"activity_types":[],"attempt_count":0,"banked_attempt_count":0,"commits":[],"dependency_impact":"none","detail_url":"problems/870.json","draft_proposals":[],"edges":[{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_86e95433811dacd7","source_root":"sha256:a4d62c3b7a2ca0a02a1bf4ce1b4ad0ffb06b6f2f61ff9f5b58ed8ee07d8b2bf1","target":"erdos:870","trust":"signed"},{"evidence":"Problem identity derived from the accepted finding's pinned source anchor.","inferred":true,"relation":"describes","source":"vf_873090b4992176be","source_root":"sha256:a4d62c3b7a2ca0a02a1bf4ce1b4ad0ffb06b6f2f61ff9f5b58ed8ee07d8b2bf1","target":"erdos:870","trust":"signed"}],"external_references":[],"formal_conjectures_activity":null,"frontier_id":"vfr_0a25edabc16db143","frontier_root":"sha256:a4d62c3b7a2ca0a02a1bf4ce1b4ad0ffb06b6f2f61ff9f5b58ed8ee07d8b2bf1","label":"Erdős 870","lenses":{"all_authored":false,"current_record":false,"mathematical_work":false,"research_plus_scouting":false},"lifecycle":"unstarted","location":"reference_only","machine_status":"not_checked","mathematical_scope":"not_applicable","method_channels":[],"nodes":[{"id":"erdos:870","inferred":false,"kind":"problem","label":"Erdős 870","path":"site/problems/870.json